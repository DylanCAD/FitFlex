{% extends 'base.html.twig' %}

{% block title %}Accueil - FitFlex{% endblock %}

{% block body %}
<div class="jumbotron">
  <div class="container position-relative text-center">
    <img src="{{ asset('image/FitflexBanniere.jpg')}}" alt="Image accueil" class="img-fluid mx-auto">
  </div>
  
    <br class="my-4">

    <div class="container">
    <div class="row">
      <div class="col-md-6">
        <h3 class="titreaccueil">FitFlex</h3>
        <p>Mon objectif est de fournir des ressources complètes, des conseils pratiques et des exercices efficaces pour vous aider à surmonter les obstacles.</p>
      </div>
      <div class="col-md-6">
        <img src="{{ asset('image/Bandeau1.jpg')}}" alt="Image à droite" class="img-fluid">
      </div>
    </div>
  </div>

<hr>

<div class="container">
<div class="row">
    <div class="col-md-4">
      <div class="image-container">
        <img src="{{ asset('image/imgBouton1.jpg')}}" alt="Image 1" class="img-fluid">
        <a href=" {{path('exercicemusculations')}} " class="btn btn-primary">Exercices de fitness</a>
      </div>
    </div>

    <div class="col-md-4">
      <div class="image-container">
        <img src="{{ asset('image/imgBouton2.jpg')}}" alt="Image 2" class="img-fluid">
        <a href=" {{path('equipements')}} " class="btn btn-primary">Equipements de fitness</a>
      </div>
    </div>

    <div class="col-md-4">
      <div class="image-container">
        <img src="{{ asset('image/imgBouton3.jpg')}}" alt="Image 3" class="img-fluid">
        <button class="btn btn-primary">Recettes de nutrition</button>
      </div>
    </div>
</div>
</div>

<hr>

<div class="container">
    <div class="row">
      <div class="col-md-6">
        <img src="{{ asset('image/Bandeau2.jpg')}}" alt="Image à gauche" class="img-fluid">
      </div>
      <div class="col-md-6">
        <h3 class="titreaccueil">Peu importe votre niveau</h3>
        <p>Rejoins notre communauté de passionnés qui se dépassent et se surpassent au quotidien pour atteindre leurs objectifs.</p>
        <p>Inscris toi dès aujourd'hui et profite de tous les avantages de FitFlex.</p>
      </div>
    </div>
  </div>

</div>
{% endblock %}
